{
  "name": "@api-gateway-ms/api-gateway",
  "version": "1.0.0",
  "description": "API Gateway - routing, auth, rate limiting, and request tracing",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@api-gateway-ms/shared": "1.0.0",
    "axios": "^1.7.2",
    "express": "^4.19.2",
    "http-proxy-middleware": "^3.0.2",
    "express-rate-limit": "^7.3.1",
    "rate-limit-redis": "^4.2.0",
    "jsonwebtoken": "^9.0.2",
    "ioredis": "^5.4.1",
    "amqplib": "^0.10.4",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "express-async-errors": "^3.1.1",
    "opossum": "^8.1.3",
    "dotenv": "^16.4.5",
    "uuid": "^9.0.1"
